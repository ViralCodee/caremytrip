# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# Homepage served by index.html
DirectoryIndex index.html

# Canonicalize the homepage: /index, /index.html  ->  /
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Redirect any direct .html request to its clean URL (301 for SEO)
RewriteCond %{THE_REQUEST} \s/+([^.\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve the .html file for a clean URL (no redirect)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^.]+?)/?$ $1.html [L]

# 404 handling
ErrorDocument 404 /404.html

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript
</IfModule>

# Caching
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|webp)$">
  Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Security Headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "^(\.env|\.git|\.gitignore|wp-config\.php|package\.json|composer\.json|\.htaccess)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Admin panel protection
<Files "admin/*">
  <IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?caremytrip\.com [NC]
    RewriteRule ^.*$ - [F]
  </IfModule>
</Files>
